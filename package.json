{
  "name": "resumify",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run deploy:pages",
    "deploy:pages": "npm run check && npm run build && wrangler pages deploy dist/client --project-name=resumify"
  },
